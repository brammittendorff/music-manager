# ─── music-manager environment variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# NEVER commit .env to git — it contains secrets.
#
# ─── REQUIRED vs OPTIONAL ────────────────────────────────────────────────────
#
#   REQUIRED (the app will not work without these):
#     MMGR_DATABASE__URL          — PostgreSQL connection string
#     MMGR_API__DISCOGS_TOKEN     — needed for release discovery via Discogs
#
#   OPTIONAL — platform checkers that need a key (checker is skipped if blank):
#     MMGR_API__SPOTIFY_CLIENT_ID / _SECRET
#       Rate limit: ~180 requests per 30-second rolling window (~6 req/s).
#       A warning is logged at startup if this is not set.
#     MMGR_API__YOUTUBE_API_KEY
#       Rate limit: 10,000 quota units/day FREE. search.list costs 100 units,
#       so you get ~100 searches/day. A warning is logged if not set.
#
#   FREE — no key needed (always enabled):
#     Deezer      — public API, ~50 req/5 sec
#     iTunes      — Apple Search API, ~20 req/min
#     Bandcamp    — HTML scraping, ~1 req/3 sec (be polite)
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL.
# If using the bundled docker-compose.yml the defaults below work out of the box.
MMGR_DATABASE__URL=postgres://mmgr:mmgr@localhost:5432/music_manager

# ─── Discogs (REQUIRED) ───────────────────────────────────────────────────────
# Personal access token used for release discovery and metadata.
# Rate limit: 60 authenticated requests/minute.
#
# How to get one:
#   1. Log in to https://www.discogs.com
#   2. Go to https://www.discogs.com/settings/developers
#   3. Click "Generate new token" under "Personal Access Tokens"
#   4. Paste it below.
MMGR_API__DISCOGS_TOKEN=your_discogs_personal_access_token_here

# ─── Spotify (OPTIONAL) ───────────────────────────────────────────────────────
# Used to check whether a release is streamable on Spotify.
# Rate limit: ~180 requests per 30-second rolling window. Spotify does not
# publish an exact per-endpoint limit; the worker uses 1 req/sec to be safe.
#
# How to get credentials:
#   1. Go to https://developer.spotify.com/dashboard
#   2. Log in and click "Create app"
#   3. Fill in a name/description; set Redirect URI to http://localhost
#   4. Copy the Client ID and Client Secret from the app settings page.
MMGR_API__SPOTIFY_CLIENT_ID=your_spotify_client_id_here
MMGR_API__SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ─── YouTube Data API v3 (OPTIONAL) ──────────────────────────────────────────
# Used to check whether a release is available on YouTube Music.
# Rate limit: 10,000 quota UNITS per day (free tier).
#   search.list = 100 units → max ~100 searches/day.
#   The worker throttles to 1 search every 15 minutes by default to stay safe.
#
# How to get a key:
#   1. Go to https://console.cloud.google.com
#   2. Create or select a project
#   3. Navigate to "APIs & Services" → "Library"
#   4. Enable "YouTube Data API v3"
#   5. Go to "APIs & Services" → "Credentials" → "Create Credentials" → "API key"
#   6. (Optional but recommended) Restrict the key to YouTube Data API v3 only.
MMGR_API__YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# ─── Search defaults (optional overrides) ────────────────────────────────────
# Uncomment to override values set in config/default.toml at runtime.
# MMGR_SEARCH__COUNTRY=Netherlands
# MMGR_SEARCH__COUNTRY_CODE=NL
# MMGR_SEARCH__YEAR_FROM=1950
# MMGR_SEARCH__YEAR_TO=1980

# ─── Logging ──────────────────────────────────────────────────────────────────
# One of: trace, debug, info, warn, error
MMGR_LOG=info
